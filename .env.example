# ─── LLM Provider ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# ─── Hermes Agent ────────────────────────────────────────
HERMES_MODEL=gemini-3-flash-preview
HERMES_VLM_MODEL=gemini-3-flash-preview
HERMES_PROVIDER=gemini
HERMES_MAX_ITERATIONS=90

# Data
CRYO_DATA_DIR=/cryo-data
CRYO_MAX_CONVERSATIONS_PER_USER=50
CRYO_MAX_WORKSPACES_PER_USER=10
CRYO_MAX_NODES_PER_WORKSPACE=50


# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cryo
POSTGRES_USER=cryo
POSTGRES_PASSWORD=cryo_secret_change_me

# ─── API Server ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-random-secret-key
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# UI Features
VITE_BIONIC_READING=false

# ─── JWT Auth ────────────────────────────────────────────
JWT_SECRET=change-this-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Bootstrap user
DEFAULT_SUPERUSER_EMAIL=creator@cryo.in
DEFAULT_SUPERUSER_USERNAME=creator
DEFAULT_SUPERUSER_PASSWORD=creator@shivam0705
DEFAULT_SUPERUSER_FULL_NAME=CRYO Creator


# Digital Twin Backbone
CRYO_DIGITAL_TWIN_BACKBONE=human1
CRYO_DIGITAL_TWIN_AUTO_FETCH=true

# NCBI / Entrez — get free key at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=

# Analysis tool binaries (conda install -c bioconda macs3 kraken2 humann fastqc bwa samtools)
MACS3_PATH=macs3
KRAKEN2_PATH=kraken2
KRAKEN2_DB=/cryo-data/kraken2/db
HUMANN3_PATH=humann
HUMANN3_DB=/cryo-data/humann3/db
FASTQC_PATH=fastqc
TRIMMOMATIC_PATH=trimmomatic
BWA_PATH=bwa
SAMTOOLS_PATH=samtools

# Analysis data paths
CRYO_UPLOAD_DIR=/cryo-data/uploads
CRYO_REPORTS_DIR=/cryo-data/reports
CRYO_CACHE_DIR=/cryo-data/cache
CCLE_PARQUET_PATH=/cryo-data/ccle/ccle_expression_human1.parquet
GDSC2_CSV_PATH=/cryo-data/gdsc/gdsc2_sensitivity.csv
DRUG_TARGETS_DB_PATH=/cryo-data/cache/drug_targets.db

# External biology API base URLs (all free, no keys needed)
CHEMBL_API_URL=https://www.ebi.ac.uk/chembl/api/data
STRINGDB_API_URL=https://string-db.org/api
KEGG_API_URL=https://rest.kegg.jp
REACTOME_API_URL=https://reactome.org/ContentService
REACTOME_ANALYSIS_URL=https://reactome.org/AnalysisService
OPENTARGETS_API_URL=https://api.platform.opentargets.org/api/v4/graphql
DGIDB_API_URL=https://dgidb.org/api/v2

# Tuning
DRUG_LOOKUP_CACHE_TTL_DAYS=7
PUBMED_MAX_RESULTS=25
STRINGDB_DEFAULT_CONFIDENCE=700
REACTOME_FDR_THRESHOLD=0.05
