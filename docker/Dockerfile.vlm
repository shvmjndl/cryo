FROM python:3.12-slim-bookworm

WORKDIR /app

COPY vlm_ocr/requirements.txt /app/vlm_ocr/requirements.txt
RUN pip install --no-cache-dir --timeout=120 --retries=5 -r vlm_ocr/requirements.txt

COPY vlm_ocr/ /app/vlm_ocr/

EXPOSE 8100

CMD ["uvicorn", "vlm_ocr.server:app", "--host", "0.0.0.0", "--port", "8100", "--reload"]
